# Application
FLEETMIND_ENVIRONMENT=development
FLEETMIND_LOG_LEVEL=INFO

# Local LLM provider
FLEETMIND_LLM_PROVIDER=ollama
FLEETMIND_LLM_MODEL=llama3.2:3b
FLEETMIND_LLM_BASE_URL=http://localhost:11434

# Embedding provider
FLEETMIND_EMBEDDING_PROVIDER=ollama
FLEETMIND_EMBEDDING_MODEL=embeddinggemma

# Vector database
FLEETMIND_QDRANT_URL=http://localhost:6333
FLEETMIND_QDRANT_COLLECTION=fleetmind_documents

# Optional observability service
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
