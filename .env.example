# Application
FLEETMIND_ENVIRONMENT=development
FLEETMIND_LOG_LEVEL=INFO

# Local LLM provider
FLEETMIND_LLM_PROVIDER=ollama
FLEETMIND_LLM_MODEL=llama3.2:3b
FLEETMIND_LLM_BASE_URL=http://localhost:11434
FLEETMIND_OLLAMA_TIMEOUT_SECONDS=120

# Embedding provider
FLEETMIND_EMBEDDING_PROVIDER=ollama
FLEETMIND_EMBEDDING_MODEL=embeddinggemma

# Vector database
# QDRANT_URL is retained for a future remote-server mode.
# The current CLI runtime uses persistent Qdrant local storage at QDRANT_PATH.
FLEETMIND_QDRANT_URL=http://localhost:6333
FLEETMIND_QDRANT_PATH=data/qdrant_local
FLEETMIND_QDRANT_COLLECTION=fleetmind_documents

# Document ingestion and retrieval
FLEETMIND_CHUNK_SIZE_WORDS=180
FLEETMIND_CHUNK_OVERLAP_WORDS=30
FLEETMIND_RETRIEVAL_LIMIT=5
FLEETMIND_MINIMUM_GROUNDING_SCORE=0.5
FLEETMIND_MAX_CONTEXT_CHARS=6000

# Optional observability service
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
